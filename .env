# =============================================================
# app_condominio - Variables de entorno DESARROLLO
# =============================================================
# Copia este archivo a .env y ajusta los valores

APP_ENV=development

# --- API Backend ---
API_BASE_URL=http://10.0.2.2:8000/api/v1
API_TIMEOUT=30000

# --- Auth ---
JWT_SECRET_KEY=dev_secret_key_change_in_prod
TOKEN_REFRESH_THRESHOLD=300

# --- Notificaciones Push (Firebase) ---
FCM_SERVER_KEY=your_fcm_server_key_here

# --- Mapas (si se requiere) ---
GOOGLE_MAPS_KEY=your_google_maps_api_key

# --- App config ---
APP_NAME=CondoAdmin
SUPPORT_EMAIL=soporte@condoadmin.com
