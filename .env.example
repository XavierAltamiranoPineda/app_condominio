# =============================================================
# app_condominio - Variables de entorno EJEMPLO
# Copia a .env y llena los valores reales
# =============================================================

APP_ENV=development         # development | staging | production

# --- API Backend ---
API_BASE_URL=http://10.0.2.2:8000/api/v1   # Para emulador Android
# API_BASE_URL=http://localhost:8000/api/v1  # Para web/desktop
API_TIMEOUT=30000

# --- Auth ---
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION
TOKEN_REFRESH_THRESHOLD=300   # segundos antes de vencimiento para refrescar

# --- Firebase (Notificaciones Push) ---
FCM_SERVER_KEY=YOUR_FCM_SERVER_KEY_HERE

# --- Google Maps ---
GOOGLE_MAPS_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# --- App Config ---
APP_NAME=CondoAdmin
SUPPORT_EMAIL=soporte@condoadmin.com
